{
  "entities": {
    "Hero": {
      "title": "Hero Section",
      "description": "The main hero section of the portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "suffix": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "workMode": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["title", "subtitle", "description"]
    },
    "Stat": {
      "title": "Statistic",
      "description": "A key performance metric.",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "value": { "type": "string" },
        "sub": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["label", "value", "icon"]
    },
    "Campaign": {
      "title": "Campaign",
      "description": "An advertising campaign's performance data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "spent": { "type": "number" },
        "result": { "type": "number" },
        "type": { "type": "string" },
        "cost": { "type": "number" },
        "impressions": { "type": "number" },
        "clicks": { "type": "number" }
      },
      "required": ["name", "spent", "result"]
    },
    "Experience": {
      "title": "Experience",
      "description": "A professional work experience entry.",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "company": { "type": "string" },
        "period": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["role", "company", "period"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A professional skill or tool.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "category"]
    },
    "Education": {
      "title": "Education",
      "description": "An academic background entry.",
      "type": "object",
      "properties": {
        "degree": { "type": "string" },
        "institution": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["degree", "institution", "period"]
    },
    "Insight": {
      "title": "Campaign Insight",
      "description": "A detailed performance insight for a campaign.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "market": { "type": "string" },
        "metrics": { "type": "array", "items": { "type": "object", "properties": { "label": { "type": "string" }, "value": { "type": "string" } } } },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["title", "market", "description"]
    }
  },
  "firestore": {
    "/settings/hero": { "schema": "Hero", "description": "Global hero section settings." },
    "/stats": { "schema": "Stat", "description": "Collection of key statistics." },
    "/campaigns/snapchat": { "schema": "Campaign", "description": "Snapchat campaign data." },
    "/campaigns/google_ads": { "schema": "Campaign", "description": "Google Ads campaign data." },
    "/campaigns/tiktok": { "schema": "Campaign", "description": "TikTok campaign data." },
    "/experiences": { "schema": "Experience", "description": "Collection of work experiences." },
    "/skills": { "schema": "Skill", "description": "Collection of professional skills." },
    "/education": { "schema": "Education", "description": "Collection of academic background entries." },
    "/insights": { "schema": "Insight", "description": "Collection of campaign performance insights." }
  }
}
