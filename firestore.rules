rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // Allow users to read and write their own data
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /hero/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /stats/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /campaigns/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /experiences/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /skills/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /projects/{document=**} {
        allow read, write: if isOwner(userId);
      }
      match /insights/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Public access to the main portfolio (if we want a default one or shared ones)
    // For now, let's assume the user wants to manage their own data.
  }
}
